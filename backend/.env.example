# Railway automatically injects DATABASE_URL when you add a Postgres plugin.
# For local dev, either set DATABASE_URL directly or fill in the individual vars below.

# Option A — full connection string (Railway sets this for you)
# DATABASE_URL=postgresql://user:password@host:5432/railway

# Option B — individual vars (local dev)
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=findings

# Comma-separated list of allowed CORS origins
# Add your Vercel URL here
ALLOWED_ORIGINS=https://findings-kappa.vercel.app,http://localhost:5173
